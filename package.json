{
  "name": "scholaid",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "dev:app": "turbo run dev --filter=api --filter=web --filter=@scholaid/ui",
    "dev:web": "turbo run dev --filter=web --filter=@scholaid/ui",
    "dev:api": "turbo run dev --filter=api"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.8"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  }
}
