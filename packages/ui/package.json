{
  "name": "@scholaid/ui",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./styles.css": "./dist/index.css",
    "./*": "./dist/*.js"
  },
  "license": "MIT",
  "scripts": {
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "check-types": "tsc --noEmit",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@scholaid/eslint-config": "workspace:*",
    "@scholaid/tailwind-config": "workspace:*",
    "@scholaid/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.3.0",
    "typescript": "5.9.3"
  }
}
